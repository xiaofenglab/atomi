#!/bin/bash

GP="$HOME/scripts/plot_dE_live_4.gp"

if [ $# -lt 1 ] || [ $# -gt 5 ]; then
  echo "Usage: plotvasp4 <vasp.out1> [vasp.out2] [vasp.out3] [vasp.out4] [window_steps]"
  exit 1
fi

args=("$@")
last="${args[$(($#-1))]}"

# If the last argument is an integer, treat it as the window size
if [[ "$last" =~ ^[0-9]+$ ]]; then
  WINDOW="$last"
  unset 'args[$(($#-1))]'
else
  WINDOW=100
fi

FILES=("${args[@]}")
NFILES=${#FILES[@]}

if [ "$NFILES" -lt 1 ] || [ "$NFILES" -gt 4 ]; then
  echo "Usage: plotvasp4 <vasp.out1> [vasp.out2] [vasp.out3] [vasp.out4] [window_steps]"
  exit 1
fi

for f in "${FILES[@]}"; do
  if [ ! -f "$f" ]; then
    echo "Error: file not found: $f"
    exit 1
  fi
done

build_gnuplot_args() {
  local n=$#
  local args_out="nfiles=$n; win=$WINDOW"
  local i=1
  for f in "$@"; do
    esc=$(printf "%s" "$f" | sed "s/'/'\\\\''/g")
    args_out="$args_out; file${i}='${esc}'"
    i=$((i+1))
  done
  printf "%s" "$args_out"
}

count_total_dav() {
  local total=0
  local c
  for f in "$@"; do
    c=$(grep -c '^DAV:' "$f" 2>/dev/null)
    total=$((total + c))
  done
  echo "$total"
}

prev=-1

clear
gnuplot -e "$(build_gnuplot_args "${FILES[@]}")" "$GP"

while true; do
  curr=$(count_total_dav "${FILES[@]}")

  if [ "$curr" -ne "$prev" ]; then
    clear
    gnuplot -e "$(build_gnuplot_args "${FILES[@]}")" "$GP"
    prev=$curr
  fi

  sleep 5
done