#!/bin/bash

FILE="$1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GP="$SCRIPT_DIR/plot_cp2k_all.gp"

if [ -z "$FILE" ]; then
  echo "Usage: plotcp2kall <cp2k.log>"
  exit 1
fi

if [ ! -f "$FILE" ]; then
  echo "Error: file not found: $FILE"
  exit 1
fi

if [ ! -f "$GP" ]; then
  echo "Error: gnuplot script not found: $GP"
  exit 1
fi

gnuplot -e "file='$FILE'" "$GP"
