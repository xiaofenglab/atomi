#!/bin/bash

if [[ $# -lt 1 ]]; then
    echo "Usage: plotcp2k <cp2k.log|out> [trajectory.xyz]"
    return 1 2>/dev/null || exit 1
fi

LOGFILE="$1"
XYZFILE="${2:-}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ ! -f "$LOGFILE" ]]; then
    echo "ERROR: file not found: $LOGFILE"
    return 1 2>/dev/null || exit 1
fi

GEO_GP="${SCRIPT_DIR}/plot_cp2k_geo_live.gp"
MD_GP="${SCRIPT_DIR}/plot_cp2k_md_live.gp"
BOND_HELPER="${SCRIPT_DIR}/cp2k_md_bondtrack.py"
ETA_HELPER="${SCRIPT_DIR}/cp2k_md_eta.py"

if [[ ! -f "$GEO_GP" ]]; then
    echo "ERROR: GEO gnuplot script not found: $GEO_GP"
    return 1 2>/dev/null || exit 1
fi

if [[ ! -f "$MD_GP" ]]; then
    echo "ERROR: MD gnuplot script not found: $MD_GP"
    return 1 2>/dev/null || exit 1
fi

if [[ ! -f "$BOND_HELPER" ]]; then
    echo "ERROR: helper script not found: $BOND_HELPER"
    return 1 2>/dev/null || exit 1
fi

if [[ ! -f "$ETA_HELPER" ]]; then
    echo "ERROR: helper script not found: $ETA_HELPER"
    return 1 2>/dev/null || exit 1
fi

# auto-find xyz if not explicitly given
if [[ -z "$XYZFILE" ]]; then
    base="${LOGFILE%.*}"

    # strongest preference: same basename + CP2K pos-style names
    for cand in \
        "${base}-pos.xyz" \
        "${base}-pos-1.xyz" \
        "${base}.pos.xyz" \
        "${base}.pos-1.xyz" \
        "${base}_pos.xyz" \
        "${base}_pos-1.xyz"
    do
        if [[ -f "$cand" ]]; then
            XYZFILE="$cand"
            break
        fi
    done

    # next: any *pos*.xyz in this folder, prefer largest/newest
    if [[ -z "$XYZFILE" ]]; then
        XYZFILE=$(python3 - "$LOGFILE" <<'PY'
from pathlib import Path
import sys
parent = Path(sys.argv[1]).resolve().parent
candidates = sorted(parent.glob("*pos*.xyz"), key=lambda p: (p.stat().st_size, p.stat().st_mtime), reverse=True)
print(candidates[0] if candidates else "")
PY
)
        XYZFILE="${XYZFILE#./}"
    fi

    # then same basename plain xyz
    if [[ -z "$XYZFILE" && -f "${base}.xyz" ]]; then
        XYZFILE="${base}.xyz"
    fi

    # last fallback: only one xyz in folder
    if [[ -z "$XYZFILE" ]]; then
        mapfile -t xyzs < <(find . -maxdepth 1 -type f -name "*.xyz" | sort)
        if [[ "${#xyzs[@]}" -eq 1 ]]; then
            XYZFILE="${xyzs[0]#./}"
        fi
    fi
fi

if grep -Eq "MD\||RUN_TYPE[[:space:]]+MD|STEP NUMBER|TEMPERATURE \[K\]" "$LOGFILE"; then
    MODE="md"
elif grep -Eq "Informations at step|OPTIMIZATION STEP|STARTING GEOMETRY OPTIMIZATION" "$LOGFILE"; then
    MODE="geo"
else
    echo "WARNING: could not confidently detect CP2K run type."
    echo "Defaulting to MD plot."
    MODE="md"
fi

echo "Detected CP2K mode: $MODE"
[[ -n "$XYZFILE" ]] && echo "Using xyz trajectory: $XYZFILE"

if [[ "$MODE" == "md" ]]; then
    if [[ -n "$XYZFILE" ]]; then
        gnuplot -e "file='${LOGFILE}'; xyzfile='${XYZFILE}'; helper_py='${BOND_HELPER}'; eta_py='${ETA_HELPER}'" "$MD_GP"
    else
        echo "WARNING: no XYZ trajectory found; bond panels will be skipped."
        gnuplot -e "file='${LOGFILE}'; helper_py='${BOND_HELPER}'; eta_py='${ETA_HELPER}'" "$MD_GP"
    fi
else
    GEODAT="cp2k_geo_steps.dat"
    SCFDAT="cp2k_geo_scf.dat"

    # -----------------------------
    # Parse GEO progress into geodat
    # columns:
    # 1 step
    # 2 total energy
    # 3 decrease in energy (1 if YES, 0 if NO/NA)
    # 4 max step size
    # 5 rms step size
    # 6 used time
    # 7 max gradient
    # 8 rms gradient
    # 9 trust radius (placeholder 0.0 for now)
    # -----------------------------
    awk '
    function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }

    /Informations at step/ {
        if (match($0, /step = *([0-9]+)/)) {
            step = substr($0, RSTART, RLENGTH)
            sub(/.*step = */, "", step)
            step = trim(step)
        }
    }

    /Total Energy[[:space:]]*=/ {
        line = $0
        sub(/.*=/, "", line)
        E = trim(line)
    }

    /Decrease in energy[[:space:]]*=/ {
        line = $0
        sub(/.*=/, "", line)
        dec = trim(line)
        if (dec == "YES") dE = 1
        else if (dec == "NO") dE = 0
        else dE = 0
    }

    /Used time[[:space:]]*=/ {
        line = $0
        sub(/.*=/, "", line)
        used = trim(line)
    }

    /Max\. step size[[:space:]]*=/ {
        line = $0
        sub(/.*=/, "", line)
        smax = trim(line)
    }

    /RMS step size[[:space:]]*=/ {
        line = $0
        sub(/.*=/, "", line)
        srms = trim(line)
    }

    /Max\. gradient[[:space:]]*=/ {
        line = $0
        sub(/.*=/, "", line)
        gmax = trim(line)
    }

    /RMS gradient[[:space:]]*=/ {
        line = $0
        sub(/.*=/, "", line)
        grms = trim(line)
        if (step != "" && E != "") {
            print step, E, dE, smax, srms, used, gmax, grms, 0.0
        }
    }
    ' "$LOGFILE" > "$GEODAT"

    # -----------------------------
    # Parse outer SCF iterations into scfdat
    # columns:
    # 1 geo step
    # 2 outer scf iter
    # 3 energy
    # 4 rms gradient
    # 5 energy (again, for old plotting usage)
    # -----------------------------
    awk '
    function trim(s) { gsub(/^[ \t]+|[ \t]+$/, "", s); return s }

    /Informations at step/ {
        if (match($0, /step = *([0-9]+)/)) {
            gstep = substr($0, RSTART, RLENGTH)
            sub(/.*step = */, "", gstep)
            gstep = trim(gstep)
        }
    }

    /outer SCF iter/ {
        iter = ""; rmsg = ""; energy = ""

        if (match($0, /outer SCF iter = *[0-9]+/)) {
            iter = substr($0, RSTART, RLENGTH)
            sub(/.*= */, "", iter)
            iter = trim(iter)
        }

        if (match($0, /RMS gradient = *[-+0-9.Ee]+/)) {
            rmsg = substr($0, RSTART, RLENGTH)
            sub(/.*= */, "", rmsg)
            rmsg = trim(rmsg)
        }

        if (match($0, /energy = *[-+0-9.Ee]+/)) {
            energy = substr($0, RSTART, RLENGTH)
            sub(/.*= */, "", energy)
            energy = trim(energy)
        }

        if (gstep != "" && iter != "" && energy != "" && rmsg != "") {
            print gstep, iter, energy, rmsg, energy
        }
    }
    ' "$LOGFILE" > "$SCFDAT"

    if [[ -n "$XYZFILE" ]]; then
        gnuplot -e "file='${LOGFILE}'; geodat='${GEODAT}'; scfdat='${SCFDAT}'; xyzfile='${XYZFILE}'; helper_py='${BOND_HELPER}'" "$GEO_GP"
    else
        gnuplot -e "file='${LOGFILE}'; geodat='${GEODAT}'; scfdat='${SCFDAT}'; helper_py='${BOND_HELPER}'" "$GEO_GP"
    fi
fi
