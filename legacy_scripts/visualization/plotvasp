#!/bin/bash

GP="$HOME/scripts/plot_dE_live.gp"

if [ $# -lt 1 ] || [ $# -gt 2 ]; then
  echo "Usage: plotvasp <vasp.out> [window_steps]"
  exit 1
fi

FILE="$1"
WINDOW="${2:-100}"

if [ ! -f "$FILE" ]; then
  echo "Error: file not found: $FILE"
  exit 1
fi

if ! [[ "$WINDOW" =~ ^[0-9]+$ ]]; then
  echo "Error: window_steps must be a positive integer"
  exit 1
fi

prev_count=-1

while true; do
  curr_count=$(grep -c '^DAV:' "$FILE" 2>/dev/null)

  if [ "$curr_count" -ne "$prev_count" ]; then
    clear
    gnuplot -e "file='$FILE'; win=$WINDOW" "$GP"
    prev_count=$curr_count
  fi

  sleep 2
done